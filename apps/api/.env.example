# Basic application mode
APP_ENVIRONMENT=local
USE_AZURE_SERVICES=false          # false = local mocks, true = Azure mode
AZURE_AUTH_MODE=api_key           # api_key is easiest for local Azure testing
MANAGED_IDENTITY_CLIENT_ID=        # leave empty for system-assigned identity

# ------- Required Azure POC settings -------
# Fill only these for the first Azure test
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_KEY=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=
AZURE_SEARCH_KEY=
COSMOS_ENDPOINT=
COSMOS_KEY=

# Optional: Foundry/Azure AI project metadata
# Leave blank for now unless you are using Foundry project metadata.
AZURE_AI_PROJECT_ENDPOINT=

# Optional: Key Vault settings
USE_KEY_VAULT=false
KEY_VAULT_URL=
AZURE_OPENAI_KEY_SECRET_NAME=azure-openai-key
AZURE_SEARCH_KEY_SECRET_NAME=azure-search-key
COSMOS_KEY_SECRET_NAME=cosmos-key
MICROSOFT_ENTRA_CLIENT_SECRET_SECRET_NAME=microsoft-entra-client-secret

# Optional: search and Cosmos customization
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_SOURCE_FIELD=source
AZURE_SEARCH_TOP_K=5
COSMOS_DATABASE_NAME=ragbot
COSMOS_SESSIONS_CONTAINER=sessions
COSMOS_EPISODIC_CONTAINER=episodic-memory

# Optional: Azure AD / Entra credentials (not needed for POC)
MICROSOFT_ENTRA_TENANT=
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=

# Backend local URL for frontend calls
API_BASE_URL=http://localhost:8000
